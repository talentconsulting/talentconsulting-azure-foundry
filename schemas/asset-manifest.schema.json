{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/asset-manifest.schema.json",
  "title": "AI Asset Manifest",
  "type": "object",
  "required": ["schema_version", "asset_type", "id", "name", "version", "status", "owner", "purpose"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "asset_type": {
      "type": "string",
      "enum": ["agent", "workflow", "prompt", "tool", "model", "dataset", "evaluation"]
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "approved", "released", "retired"]
    },
    "owner": {
      "type": "object",
      "required": ["team"],
      "properties": {
        "team": {
          "type": "string"
        },
        "accountable_person": {
          "type": "string"
        }
      }
    },
    "purpose": {
      "type": "string"
    }
  }
}

